# DirFuzz MCP Server Environment Example
# Copy these into your shell environment, a Claude Desktop env block, or a .env loader for the dirfuzz-mcp process.
# The MCP server reads configuration exclusively from environment variables; it does not read dirfuzz.yaml.

# Required directories
DIRFUZZ_WORDLIST_DIR=/absolute/path/to/DirFuzz/wordlists
DIRFUZZ_SCOPE_DIR=/absolute/path/to/h1-scope-watcher/output
DIRFUZZ_OUTPUT_DIR=/absolute/path/to/DirFuzz/output

# Optional tuning
# Acceptable range: positive integer >= 1
DIRFUZZ_MAX_THREADS=15

# Optional output bounding
# Acceptable range: positive integer >= 1
DIRFUZZ_MAX_RESULTS=200

# Optional concurrent-scan guard
# Acceptable range: positive integer >= 1
DIRFUZZ_MAX_CONCURRENT_SCANS=5

# Optional rate limiting
# Acceptable range: positive integer >= 1
DIRFUZZ_SCAN_RATE_LIMIT=20
# Acceptable range: positive integer >= 1
DIRFUZZ_TOOL_RATE_LIMIT=60
# Acceptable range: positive integer >= 1
DIRFUZZ_RATE_LIMIT_WINDOW_SECONDS=600

# Optional audit log
# Default when unset: $DIRFUZZ_OUTPUT_DIR/dirfuzz-audit.jsonl
DIRFUZZ_AUDIT_LOG=/absolute/path/to/DirFuzz/output/dirfuzz-audit.jsonl
